#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

desc="$*"

if [[ -z "$desc" ]]; then
   err "Missing description"
   hint "imp branch <description>"
   exit 1
fi

header "Branch"

muted "Generating name..."
echo

name=$(ai_fast "$(prompt_branch "$desc")")
name=$(echo "$name" | tr -d '[:space:]')

validate_branch "$name"

label "Suggested"
echo "  $name"
echo

if confirm "Create branch?"; then
   git checkout -b "$name"
   success "Switched to $name"
   hint "make changes, then imp commit"
else
   muted "Cancelled"
fi
