#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git
require_gh

header "Pull Request"

branch=$(git branch --show-current)
base=$(base_branch)

if [[ "$branch" == "$base" ]]; then
   err "Cannot create PR from $branch"
   hint "imp branch <description>"
   exit 1
fi

log=$(git log --oneline "$base..$branch" 2> /dev/null || true)

if [[ -z "$log" ]]; then
   err "No commits on $branch"
   exit 1
fi

label "Branch"
echo "  $branch → $base"
echo

show_items "Commits" "$log"

muted "Generating PR..."
echo

diff=$(git diff "$base..$branch" | head -1000)

pr_content=$(ai_smart "$(prompt_pr "$branch" "$log" "$diff")")

title=$(echo "$pr_content" | grep "^TITLE:" | sed 's/^TITLE: //')
description=$(echo "$pr_content" | sed '1,/^DESCRIPTION:/d')

if [[ -z "$title" ]]; then
   warn "Could not parse title, using branch name"
   title="$branch"
fi

label "Title"
echo "  $title"
echo
label "Description"
divider
echo "$description" | md
divider
echo

read -rp "Create PR? [y/N/e] " choice

case "$choice" in
   e | E)
      tmpfile=$(mktemp)
      printf "%s\n\n%s" "$title" "$description" > "$tmpfile"
      ${EDITOR:-vim} "$tmpfile"
      title=$(head -1 "$tmpfile")
      description=$(tail -n +3 "$tmpfile")
      rm -f "$tmpfile"
      ;;
   y | Y) ;;
   *)
      muted "Cancelled"
      exit 0
      ;;
esac

if ! has_upstream; then
   muted "Pushing to origin..."
   git push -u origin "$branch"
fi

pr_url=$(gh pr create --title "$title" --body "$description" --base "$base" 2>&1) || {
   err "Failed to create PR"
   exit 1
}

echo
success "Created PR"
echo "  $pr_url"

hint "gh pr view --web to open in browser"
