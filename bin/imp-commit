#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

# Handle -a flag
stage_all=false
if [[ "${1:-}" == "-a" ]]; then
   stage_all=true
fi

if [[ "$stage_all" == "true" ]]; then
   git add -A
fi

diff=$(git diff --cached)

if [[ -z "$diff" ]]; then
   err "Nothing staged"
   hint "git add <files>, or imp commit -a"
   exit 1
fi

header "Commit"

muted "Generating message..."
echo

msg=$(ai_fast "Generate a git commit message for this diff.

Rules:
- First line: imperative mood, max 50 chars
- No markdown, no backticks
- Focus on WHY not WHAT

Diff:
$diff

Output ONLY the commit message, nothing else:")

divider
echo "$msg"
divider
echo

read -rp "Use this message? [Y/n/e] " choice

case "$choice" in
   n | N)
      muted "Cancelled"
      exit 0
      ;;
   e | E)
      git commit -e -m "$msg"
      ;;
   *)
      git commit -m "$msg"
      ;;
esac

success "Committed"
hint "imp commit again, or imp release when ready"
