#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

repo=$(basename "$(git rev-parse --show-toplevel)")
branch=$(git branch --show-current)
tag=$(last_tag)

header "$repo"

label "Branch"
echo "  $branch"
echo

# Uncommitted changes
changes=$(git status --porcelain)
if [[ -n "$changes" ]]; then
   label "Uncommitted"
   echo "$changes" | while read -r line; do
      item "$line"
   done
   echo
fi

# Unpushed commits
if [[ -n "$tag" ]]; then
   unpushed=$(git log --oneline "$tag..HEAD" 2> /dev/null || true)
else
   unpushed=$(git log --oneline -10 2> /dev/null || true)
fi

if [[ -n "$unpushed" ]]; then
   count=$(echo "$unpushed" | wc -l | tr -d ' ')
   label "Commits since ${tag:-start} ($count)"
   echo "$unpushed" | while read -r line; do
      item "$line"
   done
   echo
fi

# Worktrees
worktrees=$(git worktree list 2> /dev/null | tail -n +1)
wt_count=$(echo "$worktrees" | wc -l | tr -d ' ')

if [[ $wt_count -gt 1 ]]; then
   label "Worktrees"
   echo "$worktrees" | while read -r line; do
      if echo "$line" | grep -q "$(pwd)"; then
         echo "  $line (here)"
      else
         item "$line"
      fi
   done
   echo
fi

# Last tag
if [[ -n "$tag" ]]; then
   muted "Last release: $tag"
fi

# Next steps
if [[ -n "$changes" ]]; then
   hint "git add <files>, then imp commit"
elif [[ -n "$unpushed" ]]; then
   hint "imp release to ship"
else
   hint "make changes, then imp commit"
fi
