#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

branch="${1:-HEAD}"
current=$(git branch --show-current)
base_br=$(base_branch)

header "Describe"

if [[ "$current" == "$base_br" || "$branch" == "$base_br" ]]; then
   tag=$(last_tag)
   base="${tag:-}"
else
   base=$(git merge-base "$base_br" "$branch" 2> /dev/null || echo "")
fi

diff=""
if [[ -n "$base" ]]; then
   diff=$(git diff "$base..$branch" 2> /dev/null | head -500)
fi

if [[ -n "$diff" ]]; then
   muted "Analyzing ${current:-$branch} since ${base}..."
   echo

   desc=$(ai_fast "$(prompt_describe "$diff" "diff")")
else
   log=$(git log --oneline -10 "$branch" 2> /dev/null || true)

   if [[ -z "$log" ]]; then
      muted "No commits found"
      exit 0
   fi

   muted "Analyzing recent commits..."
   echo

   desc=$(ai_fast "$(prompt_describe "$log" "log")")
fi

divider
echo "$desc" | md
divider

hint "imp release to ship, or imp list for overview"
