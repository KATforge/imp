#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

header "Diff"

if ! get_diff "${1:-}"; then
   muted "No changes"
   exit 0
fi

muted "Analyzing $DIFF_CONTEXT..."
echo

explanation=$(ai_fast "$(prompt_diff "$DIFF")")

divider
echo "$explanation" | md
divider

hint "imp commit to commit, or imp commit -a to stage and commit"
