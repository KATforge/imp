#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

header "Doctor"

ok=true

check() {
   local name="$1"
   local cmd="$2"
   local url="$3"
   local required="${4:-true}"

   if command -v "$cmd" &> /dev/null; then
      version=$("$cmd" --version 2>&1 | head -1)
      success "$name ($version)"
   elif [[ "$required" == "true" ]]; then
      err "$name not found"
      item "$url"
      ok=false
   else
      muted "  $name not found (optional)"
      item "$url"
   fi
}

check "git" "git" "https://git-scm.com"
check "claude" "claude" "https://docs.anthropic.com/en/docs/claude-code" "false"
check "ollama" "ollama" "https://ollama.com" "false"
check "gh" "gh" "https://cli.github.com" "false"
check "jq" "jq" "https://jqlang.github.io/jq/download" "false"
check "glow" "glow" "https://github.com/charmbracelet/glow" "false"

echo

if ! command -v claude &> /dev/null && ! command -v ollama &> /dev/null; then
   err "No AI provider found (need claude or ollama)"
   ok=false
fi

if [[ -n "${IMP_AI_PROVIDER:-}" ]]; then
   muted "Provider: $IMP_AI_PROVIDER"
else
   muted "Provider: claude (default)"
fi

if [[ -n "${IMP_AI_MODEL_FAST:-}" ]]; then
   muted "Fast model: $IMP_AI_MODEL_FAST"
fi

if [[ -n "${IMP_AI_MODEL_SMART:-}" ]]; then
   muted "Smart model: $IMP_AI_MODEL_SMART"
fi

echo

if [[ "$ok" == "true" ]]; then
   success "All good"
else
   warn "Some issues found"
   exit 1
fi
