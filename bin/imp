#!/bin/bash
set -euo pipefail

IMP_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

BOLD='\033[1m'
MUTED='\033[0;90m'
RESET='\033[0m'

usage() {
   echo
   echo -e "${BOLD}imp${RESET} — AI-powered git workflow"
   echo
   echo -e "${MUTED}Commands${RESET}"
   echo "  commit     Generate commit message (-a to stage all)"
   echo "  release    Squash, changelog, tag, and push"
   echo "  branch     Create branch from description"
   echo "  describe   Explain what a branch does"
   echo "  list       Show repo overview"
   echo
   echo -e "${MUTED}Config${RESET}"
   echo "  IMP_AI_PROVIDER     claude, ollama (default: claude)"
   echo "  IMP_AI_MODEL_FAST   quick tasks (default: haiku)"
   echo "  IMP_AI_MODEL_SMART  complex tasks (default: sonnet)"
   echo
}

cmd="${1:-}"

[[ -z "$cmd" ]] && {
   usage
   exit 0
}

script="$IMP_ROOT/bin/imp-$cmd"

if [[ -x "$script" ]]; then
   shift
   exec "$script" "$@"
else
   echo "Unknown command: $cmd" >&2
   usage
   exit 1
fi
