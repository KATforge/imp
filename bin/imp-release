#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git
require_clean "imp commit or imp stash first"

CHANGELOG="CHANGELOG.md"

tag=$(last_tag)

if [[ -n "$tag" ]]; then
   log=$(git log --oneline "$tag..HEAD" 2> /dev/null || true)
fi

# If no reachable tag or no commits since it, fall back to recent commits
if [[ -z "${log:-}" ]]; then
   log=$(git log --oneline -20 2> /dev/null || true)
   tag=""
fi

if [[ -z "$log" ]]; then
   muted "No commits to release"
   exit 0
fi

count=$(echo "$log" | wc -l | tr -d ' ')

header "Release"

show_items "Commits since ${tag:-beginning}" "$log"

# Use highest existing tag (local or fetched) for version calculation
highest=$(git tag -l 'v*' --sort=-v:refname 2> /dev/null | head -1)
current="${highest#v}"
current="${current:-0.0.0}"

patch_ver=$(bump_version "$current" patch)
minor_ver=$(bump_version "$current" minor)
major_ver=$(bump_version "$current" major)

if [[ "$HAS_GUM" == "true" ]]; then
   muted "Current: $current"
   echo
   choice=$(gum choose \
      --header "Version bump" \
      "patch  $patch_ver" \
      "minor  $minor_ver" \
      "major  $major_ver" \
      "custom" \
      "quit")
   case "$choice" in
      patch*) new_version="$patch_ver" ;;
      minor*) new_version="$minor_ver" ;;
      major*) new_version="$major_ver" ;;
      custom)
         new_version=$(gum_input "Version:" "$patch_ver")
         ;;
      *)
         muted "Cancelled"
         exit 0
         ;;
   esac
else
   label "Version bump"
   echo "  p  patch   $patch_ver"
   echo "  m  minor   $minor_ver"
   echo "  M  major   $major_ver"
   echo "  c  custom"
   echo "  q  quit"
   echo
   muted "Current: $current"
   echo

   read -rp "Choice: " choice

   case "$choice" in
      p | P) new_version="$patch_ver" ;;
      m) new_version="$minor_ver" ;;
      M) new_version="$major_ver" ;;
      c | C)
         read -rp "Version: " new_version
         ;;
      *)
         muted "Cancelled"
         exit 0
         ;;
   esac
fi

if git rev-parse "v$new_version" &> /dev/null; then
   err "Tag v$new_version already exists"
   hint "pick a different version, or: git tag -d v$new_version"
   exit 1
fi

entry=$(spin "Analyzing changes..." ai_smart "$(prompt_changelog "$log")")

label "v$new_version"
divider
echo "$entry" | md
divider
echo

if [[ "$HAS_GUM" == "true" ]]; then
   confirm_release=$(gum choose --header "Release v$new_version?" "Yes" "Edit" "No")
else
   read -rp "Release v$new_version? [y/N/e] " confirm_release
fi
case "$confirm_release" in
   e | E | Edit)
      entry=$(edit_in_editor "$entry")
      echo
      label "v$new_version (edited)"
      divider
      echo "$entry" | md
      divider
      echo
      if ! confirm "Release v$new_version?" "n"; then
         muted "Cancelled"
         exit 0
      fi
      ;;
   y | Y | Yes) ;;
   *)
      muted "Cancelled"
      exit 0
      ;;
esac

will_push=false
if confirm "Push after release?"; then
   will_push=true
   remote=$(git remote | head -1)
   if [[ -z "$remote" ]]; then
      err "No remote configured"
      hint "git remote add origin <url>"
      exit 1
   fi
fi

summary=$(spin "Generating summary..." ai_fast "$(prompt_release_summary "$entry")")
today=$(date +%Y-%m-%d)
new_entry="## [$new_version] - $today

$entry"

original_head=$(git rev-parse HEAD)
original_changelog=""
if [[ -f "$CHANGELOG" ]]; then
   original_changelog=$(cat "$CHANGELOG")
fi

committed=false

rollback() {
   echo
   warn "Rolling back..."
   git tag -d "v$new_version" 2> /dev/null || true
   if [[ "$committed" == "true" ]]; then
      git reset --hard "$original_head" 2> /dev/null || true
   fi
   if [[ -n "$original_changelog" ]]; then
      echo "$original_changelog" > "$CHANGELOG"
   else
      rm -f "$CHANGELOG"
   fi
   err "Release failed"
   exit 1
}

trap rollback ERR

if [[ -f "$CHANGELOG" ]]; then
   tmpfile=$(mktemp)
   if grep -q "## \[Unreleased\]" "$CHANGELOG"; then
      awk -v entry="$new_entry" '
         { print }
         /## \[Unreleased\]/ && !done { print ""; print entry; done=1 }
      ' "$CHANGELOG" > "$tmpfile"
   else
      awk -v entry="$new_entry" '
         /^## / && !done { print entry; print ""; done=1 }
         { print }
      ' "$CHANGELOG" > "$tmpfile"
   fi
   mv "$tmpfile" "$CHANGELOG"
else
   cat > "$CHANGELOG" << EOF
# Changelog

All notable changes to this project will be documented in this file.

$new_entry
EOF
fi

success "Updated CHANGELOG.md"

can_squash=false
if [[ -n "$tag" ]]; then
   if has_upstream; then
      unpushed=$(git log --oneline "@{u}..HEAD" 2> /dev/null || true)
      if [[ -n "$unpushed" ]]; then
         can_squash=true
      fi
   else
      can_squash=true
   fi
fi

commit_body=$(printf "%s\n\n%s" "$summary" "$entry")

if [[ "$can_squash" == "true" ]]; then
   git add "$CHANGELOG"
   git reset --soft "$tag"
   git commit -m "$commit_body"
   committed=true
   success "Squashed $count commits"
else
   git add "$CHANGELOG"
   git commit -m "$commit_body"
   committed=true
   if [[ -n "$tag" ]]; then
      muted "Commits already pushed, skipped squash"
   fi
fi

git tag "v$new_version"
success "Tagged v$new_version"

trap - ERR

if [[ "$will_push" == "true" ]]; then
   if has_upstream; then
      if [[ "$can_squash" == "true" ]]; then
         git push --force-with-lease
      else
         git push
      fi
   else
      branch=$(git branch --show-current)
      git push -u origin "$branch"
   fi
   git push origin "v$new_version"
   success "Pushed to origin"
fi

hint "make changes, then imp commit"
