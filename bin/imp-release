#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git
require_clean "imp commit or imp stash first"

CHANGELOG="CHANGELOG.md"

tag=$(last_tag)

if [[ -n "$tag" ]]; then
   log=$(git log --oneline "$tag..HEAD" 2> /dev/null || true)
else
   log=$(git log --oneline -20 2> /dev/null || true)
fi

if [[ -z "$log" ]]; then
   muted "No commits since ${tag:-beginning}"
   exit 0
fi

count=$(echo "$log" | wc -l | tr -d ' ')

header "Release"

show_items "Commits since ${tag:-beginning}" "$log"

current=""
if [[ -n "$tag" ]]; then
   current="${tag#v}"
fi
current="${current:-0.0.0}"

label "Version bump"
echo "  p  patch   $(bump_version "$current" patch)"
echo "  m  minor   $(bump_version "$current" minor)"
echo "  M  major   $(bump_version "$current" major)"
echo "  c  custom"
echo "  q  quit"
echo
muted "Current: $current"
echo

read -rp "Choice: " choice

case "$choice" in
   p | P) new_version=$(bump_version "$current" patch) ;;
   m) new_version=$(bump_version "$current" minor) ;;
   M) new_version=$(bump_version "$current" major) ;;
   c | C)
      read -rp "Version: " new_version
      ;;
   *)
      muted "Cancelled"
      exit 0
      ;;
esac

echo
muted "Analyzing changes..."

entry=$(ai_smart "$(prompt_changelog "$log")")

echo
label "v$new_version"
divider
echo "$entry" | md
divider
echo

read -rp "Release v$new_version? [y/N/e] " confirm_release
case "$confirm_release" in
   e | E)
      entry=$(edit_in_editor "$entry")
      echo
      label "v$new_version (edited)"
      divider
      echo "$entry" | md
      divider
      echo
      read -rp "Release v$new_version? [y/N] " confirm_release
      if [[ ! "$confirm_release" =~ ^[Yy]$ ]]; then
         muted "Cancelled"
         exit 0
      fi
      ;;
   y | Y) ;;
   *)
      muted "Cancelled"
      exit 0
      ;;
esac

will_push=false
read -rp "Push after release? [y/N] " confirm_push
if [[ "$confirm_push" =~ ^[Yy]$ ]]; then
   will_push=true
   remote=$(git remote | head -1)
   if [[ -z "$remote" ]]; then
      err "No remote configured"
      hint "git remote add origin <url>"
      exit 1
   fi
fi

summary=$(ai_fast "$(prompt_release_summary "$entry")")

today=$(date +%Y-%m-%d)
new_entry="## [$new_version] - $today

$entry"

original_head=$(git rev-parse HEAD)
original_changelog=""
if [[ -f "$CHANGELOG" ]]; then
   original_changelog=$(cat "$CHANGELOG")
fi

committed=false

rollback() {
   echo
   warn "Rolling back..."
   git tag -d "v$new_version" 2> /dev/null || true
   if [[ "$committed" == "true" ]]; then
      git reset --hard "$original_head" 2> /dev/null || true
   fi
   if [[ -n "$original_changelog" ]]; then
      echo "$original_changelog" > "$CHANGELOG"
   else
      rm -f "$CHANGELOG"
   fi
   err "Release failed"
   exit 1
}

trap rollback ERR

echo

if [[ -f "$CHANGELOG" ]]; then
   tmpfile=$(mktemp)
   if grep -q "## \[Unreleased\]" "$CHANGELOG"; then
      awk -v entry="$new_entry" '
         { print }
         /## \[Unreleased\]/ && !done { print ""; print entry; done=1 }
      ' "$CHANGELOG" > "$tmpfile"
   else
      awk -v entry="$new_entry" '
         /^## / && !done { print entry; print ""; done=1 }
         { print }
      ' "$CHANGELOG" > "$tmpfile"
   fi
   mv "$tmpfile" "$CHANGELOG"
else
   cat > "$CHANGELOG" << EOF
# Changelog

All notable changes to this project will be documented in this file.

$new_entry
EOF
fi

success "Updated CHANGELOG.md"

can_squash=false
if [[ -n "$tag" ]]; then
   if has_upstream; then
      unpushed=$(git log --oneline "@{u}..HEAD" 2> /dev/null || true)
      if [[ -n "$unpushed" ]]; then
         can_squash=true
      fi
   else
      can_squash=true
   fi
fi

commit_body=$(printf "%s\n\n%s" "$summary" "$entry")

if [[ "$can_squash" == "true" ]]; then
   git add "$CHANGELOG"
   git reset --soft "$tag"
   git commit -m "$commit_body"
   committed=true
   success "Squashed $count commits"
else
   git add "$CHANGELOG"
   git commit -m "$commit_body"
   committed=true
   if [[ -n "$tag" ]]; then
      muted "Commits already pushed, skipped squash"
   fi
fi

git tag "v$new_version"
success "Tagged v$new_version"

trap - ERR

if [[ "$will_push" == "true" ]]; then
   if has_upstream; then
      git push
   else
      branch=$(git branch --show-current)
      git push -u origin "$branch"
   fi
   git push --tags
   success "Pushed to origin"
fi

hint "make changes, then imp commit"
