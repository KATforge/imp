#!/bin/bash
set -euo pipefail

source "$(dirname "$0")/../lib/common.sh"

require_git

header "Amend"

total=$(commit_count)
if [[ "$total" -eq 0 ]]; then
   err "No commits to amend"
   hint "imp commit first"
   exit 1
fi

staged=$(git diff --cached)

if [[ -n "$staged" ]]; then
   show_items "Staged" "$(git diff --cached --name-only)"
fi

last_msg=$(git log -1 --pretty=%B | head -1)

if [[ "$total" -eq 1 ]]; then
   combined=$(git show --format= HEAD)
   [[ -n "$staged" ]] && combined="${combined}"$'\n'"${staged}"
else
   combined=$(git diff HEAD~1)
fi

if [[ -z "$combined" ]]; then
   err "Nothing to amend"
   exit 1
fi

muted "Generating message..."
echo

msg=$(ai_fast "$(prompt_commit "$combined")")

label "Previous"
item "$last_msg"
echo
label "New"

if ! confirm_commit "$msg" --amend; then
   muted "Cancelled"
   exit 0
fi

success "Amended"
hint "imp commit again, or imp release when ready"
